# Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=5001

# Database
MONGODB_URI=mongodb://localhost:27017/karalaya

# JWT Configuration (SECURITY CRITICAL)
# Use a strong, random secret key (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_change_this
JWT_EXPIRE=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Security Settings (Optional - defaults are provided)
# Rate Limiting
MAX_ATTEMPTS_PER_EMAIL=5
MAX_ATTEMPTS_PER_IP=10
LOCKOUT_DURATION_MINUTES=15
ATTEMPT_WINDOW_MINUTES=15

# API Rate Limiting
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=1000

# Tax Configuration
GST_PERCENTAGE=18

# Email Configuration (for future features)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Email Configuration (Gmail SMTP)
# NOTE: For Gmail, enable 2FA and use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
INTERNAL_EMAIL=internal-team@yourdomain.com
FROM_NAME=KMK Hall & Banquets

# 🔒 SECURITY NOTES:
# 1. NEVER commit .env file to version control
# 2. Use different JWT_SECRET for each environment (dev, staging, prod)
# 3. Rotate JWT_SECRET periodically in production
# 4. Use strong, random secrets (not dictionary words)
# 5. Keep NODE_ENV=production in production deployments
# 6. Enable HTTPS in production
# 7. Review security logs regularly
